rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isRideMember(rideId, userId) {
      return exists(/databases/$(database)/documents/rides/$(rideId))
        && userId in get(/databases/$(database)/documents/rides/$(rideId)).data.memberIds;
    }

    // ---------------------------------------------------------------------
    // READS: any signed-in user may read any document. This matches the
    // app's existing behavior — profiles, rides, and chats are all read
    // broadly. Note: Firestore rules are ADDITIVE (an operation is allowed
    // if ANY match grants it), so writes are handled per-collection below
    // rather than with a broad write rule.
    // ---------------------------------------------------------------------
    match /{document=**} {
      allow read: if request.auth != null;
    }

    // ---------------------------------------------------------------------
    // USERS: a signed-in user may write ONLY their own document, and may
    // NEVER set `isAdmin` / `admin`. Admin status is defined solely by the
    // Firebase Auth custom claim `admin` (set server-side by the admin API),
    // so no client can self-promote by writing to their own profile.
    // ---------------------------------------------------------------------
    match /users/{userId} {
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['isAdmin', 'admin']);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------------------
    // RIDES + group chat: authenticated writes (unchanged behavior).
    // ---------------------------------------------------------------------
    match /rides/{rideId} {
      allow write: if request.auth != null;
    }

    match /rides/{rideId}/messages/{messageId} {
      allow write: if request.auth != null;
    }

    // Post-ride reviews: one doc per rider. A rider may only write their own
    // review, only for a ride they were on, with an integer 1-5 rating and a
    // boolean `completed`. Re-submitting overwrites their previous vote; the
    // running aggregate lives on the ride doc (see services/rideReviews.ts).
    match /rides/{rideId}/reviews/{userId} {
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && isRideMember(rideId, request.auth.uid)
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.completed is bool;
      allow delete: if false;
    }

    // Per-user chat read state: only the owner, and only while they are a
    // member of the ride. (Stricter than the old catch-all, which let any
    // signed-in user write anyone's read state.)
    match /rides/{rideId}/readState/{userId} {
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && isRideMember(rideId, request.auth.uid);
      allow delete: if false;
    }

    // ---------------------------------------------------------------------
    // Other client-written collections: authenticated writes (unchanged).
    // ---------------------------------------------------------------------
    match /reports/{reportId}      { allow write: if request.auth != null; }
    match /supportRequests/{docId} { allow write: if request.auth != null; }
    match /bugReports/{docId}      { allow write: if request.auth != null; }
    match /rideFeedback/{docId}    { allow write: if request.auth != null; }

    // App config is read-only to clients (managed via the console / Admin SDK).
    match /config/{docId} {
      allow write: if false;
    }
  }
}
