rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isRideMember(rideId, userId) {
      return exists(/databases/$(database)/documents/rides/$(rideId))
        && userId in get(/databases/$(database)/documents/rides/$(rideId)).data.memberIds;
    }

    match /rides/{rideId}/readState/{userId} {
      allow read: if request.auth != null && isRideMember(rideId, request.auth.uid);
      allow create, update, set: if request.auth != null
        && request.auth.uid == userId
        && isRideMember(rideId, request.auth.uid);
      allow delete: if false;
    }

    // Existing app rules go here. Default to authenticated access to avoid regressions;
    // tighten per-collection as needed.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
